{
  "name": "pubg-point-rankings",
  "version": "0.1.0",
  "private": true,
  "description": "PUBG Point Rankings using Overwolf Electron",
  "main": "index.js",
  "author": "lzx",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development npm run build && ow-electron .",
    "dev:watch": "npm-run-all --parallel dev:ts:watch dev:renderer:assets:watch",
    "dev:ts:watch": "tsc -b --watch",
    "dev:renderer:assets:watch": "npm run copy:assets:watch --workspace @pubg-point-rankings/renderer",
    "build": "tsc -b && npm run bundle",
    "build:shared": "npm run build --workspace @pubg-point-rankings/shared",
    "build:main": "npm run build --workspace @pubg-point-rankings/main",
    "build:renderer": "npm run build --workspace @pubg-point-rankings/renderer",
    "build:watch": "npm run dev:watch",
    "bundle": "npm run bundle --workspace @pubg-point-rankings/main && npm run bundle --workspace @pubg-point-rankings/renderer",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run build && node --test \"packages/main/dist/**/*.test.js\"",
    "clean": "npm run clean --workspaces && rm -rf dist-electron",
    "postinstall": "npm run build:shared",
    "rebuild:native": "ow-electron-builder install-app-deps --config electron-builder.config.js",
    "package": "npm run build && ow-electron-builder --publish=never --config electron-builder.config.js",
    "package:dir": "npm run build && ow-electron-builder --dir --config electron-builder.config.js",
    "dist": "npm run build && ow-electron-builder --publish=never --config electron-builder.config.js",
    "dist:win": "npm run build && ow-electron-builder --win --publish=never --config electron-builder.config.js",
    "dist:mac": "npm run build && ow-electron-builder --mac --publish=never --config electron-builder.config.js",
    "dist:linux": "npm run build && ow-electron-builder --linux --publish=never --config electron-builder.config.js",
    "lint": "echo 'No linter configured yet'",
    "electron": "electron .",
    "electron:debug": "cross-env NODE_ENV=development DEBUG=* electron .",
    "ow:start": "ow-electron ."
  },
  "devDependencies": {
    "@overwolf/ow-electron": "latest",
    "@overwolf/ow-electron-builder": "latest",
    "@types/node": "^20.10.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@pubg-point-rankings/main": "^0.1.0",
    "@pubg-point-rankings/renderer": "^0.1.0",
    "@pubg-point-rankings/shared": "^0.1.0"
  },
  "overwolf": {
    "packages": [
      "gep",
      "overlay"
    ]
  },
  "keywords": ["pubg", "overwolf", "electron", "plugin"]
}
