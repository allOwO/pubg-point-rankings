{
  "name": "pubg-point-rankings",
  "version": "0.1.1",
  "private": true,
  "description": "PUBG Point Rankings using Tauri",
  "author": "lzx",
  "license": "SUL-1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run tauri:dev",
    "dev:watch": "npm run tauri:renderer:dev",
    "build": "tsc -b && npm run bundle --workspace @pubg-point-rankings/renderer",
    "build:shared": "npm run build --workspace @pubg-point-rankings/shared",
    "build:main": "npm run build --workspace @pubg-point-rankings/main",
    "build:renderer": "npm run build --workspace @pubg-point-rankings/renderer",
    "build:watch": "npm run dev:watch",
    "bundle": "npm run bundle --workspace @pubg-point-rankings/renderer",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run build && node --test \"packages/main/dist/**/*.test.js\"",
    "clean": "npm run clean --workspaces && rm -rf dist-electron src-tauri/target",
    "postinstall": "npm run build:shared",
    "package": "npm run tauri:build",
    "package:dir": "npm run tauri:build -- --bundles app",
    "dist": "npm run tauri:build",
    "dist:win": "npm run tauri:build -- --bundles nsis",
    "dist:mac": "CI=true npm run tauri:build -- --bundles dmg",
    "dist:linux": "npm run tauri:build -- --bundles appimage,deb",
    "tauri": "tauri",
    "tauri:renderer:dev": "npm run dev --workspace @pubg-point-rankings/renderer",
    "tauri:renderer:build": "npm run bundle --workspace @pubg-point-rankings/renderer",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "echo 'No linter configured yet'"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^20.10.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@pubg-point-rankings/main": "^0.1.0",
    "@pubg-point-rankings/renderer": "^0.1.0",
    "@pubg-point-rankings/shared": "^0.1.0"
  },
  "keywords": ["pubg", "tauri", "desktop", "plugin"]
}
