  "description": "PUBG Point Rankings - Tauri Renderer",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite dev --config vite.config.ts --host 127.0.0.1 --port 1420",
