{
  "name": "@pubg-point-rankings/renderer",
  "version": "0.1.0",
  "private": true,
  "description": "PUBG Point Rankings - Electron Renderer Process",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "npm-run-all --parallel build:watch copy:assets:watch",
    "build": "tsc && npm run copy:assets",
    "build:watch": "tsc --watch",
    "bundle": "node esbuild.config.mjs",
    "copy:assets": "cp src/index.html dist/ && cp src/styles.css dist/",
    "copy:assets:watch": "chokidar \"src/index.html\" \"src/styles.css\" -c \"npm run copy:assets\"",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet\"",
    "clean": "rm -rf dist bundle"
  },
  "dependencies": {
    "@pubg-point-rankings/shared": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "chokidar-cli": "^3.0.0",
    "electron": "^28.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "electron": ">=28.0.0"
  },
  "keywords": ["pubg", "overwolf", "electron", "renderer"],
  "author": "",
  "license": "MIT"
}
