{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@pubg-point-rankings/shared": ["packages/shared"],
      "@pubg-point-rankings/shared/*": ["packages/shared/*"],
      "@pubg-point-rankings/main": ["packages/main"],
      "@pubg-point-rankings/main/*": ["packages/main/*"],
      "@pubg-point-rankings/renderer": ["packages/renderer"],
      "@pubg-point-rankings/renderer/*": ["packages/renderer/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/main" },
    { "path": "./packages/renderer" }
  ],
  "exclude": ["node_modules", "dist", "dist-electron"]
}
